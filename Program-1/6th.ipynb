   "source": [
    "Q-6: Find the determinant of a matrix using Scipy *?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "81667d0c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "2\n",
      "The determinant of the array is: -320.0\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "from scipy import linalg\n",
    "\n",
    "arr = np.array ([\n",
    "    [9, 2, 3], \n",
    "    [4, 5, 6], \n",
    "    [7, 8, 1]\n",
    "])\n",
    "\n",
    "print (arr.ndim)\n",
    "\n",
    "det_arr = linalg.det(arr)\n",
    "print (f\"The determinant of the array is: {det_arr}\")"
   ]
  }
 ],
