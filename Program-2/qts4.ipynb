   ],
   "source": [
    "# A Series object can be created by assigning custom (individual) indices to each element.\n",
    "\n",
    "import pandas as pd\n",
    "pandas_series = pd.Series([\"apple\", \"banana\", \"cherry\"], index=[\"fruit1\", \"fruit2\", \"fruit3\"])\n",
    "print(pandas_series)"
   ]
  }
