     "output_type": "stream",
     "text": [
      "Values: ['apple' 'cherry' 'grapes']\n",
      "Index: Index(['i1', 'i2', 'i3'], dtype='object')\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "\n",
    "pandas_series = pd.Series([\"apple\", \"cherry\", \"grapes\"], [\"i1\", \"i2\", \"i3\"])\n",
    "\n",
    "print(\"Values:\", pandas_series.values)\n",
    "print(\"Index:\", pandas_series.index)"
   ]
  }
