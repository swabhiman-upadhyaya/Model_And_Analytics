   "source": [
    "import pandas as pd\n",
    "marks = pd.Series([85, 90, 78], index=['Maths', 'Science', 'English'])\n",
    "\n",
    "print(marks['Science'])\n",
    "\n",
    "print(marks.loc['English'])\n",
    "\n",
    "print(marks.iloc[0])"
   ]
